NODE_ENV=development
PORT=3000

# Generate keys with:
#   mkdir keys
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out keys/access_private.pem
#   openssl pkey -in keys/access_private.pem -pubout -out keys/access_public.pem
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out keys/refresh_private.pem
#   openssl pkey -in keys/refresh_private.pem -pubout -out keys/refresh_public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_PRIVATE_KEY_PATH=./keys/access_private.pem
JWT_ACCESS_PUBLIC_KEY_PATH=./keys/access_public.pem
JWT_REFRESH_PRIVATE_KEY_PATH=./keys/refresh_private.pem
JWT_REFRESH_PUBLIC_KEY_PATH=./keys/refresh_public.pem

JWT_ISSUER=jwt-demo
JWT_AUDIENCE=jwt-demo-clients

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

BCRYPT_ROUNDS=12

# Comma-separated usernames that are auto-promoted to 'admin' on /register.
# Everyone else registers as 'user'. Promote/demote later via PATCH /admin/users/:username/role.
ADMIN_USERNAMES=root,admin
